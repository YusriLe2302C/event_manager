# ================================================================
#  COLLEGE EVENTS PLATFORM — Environment Variables
#  Copy this file to .env and fill in real values.
#  NEVER commit .env to version control.
# ================================================================

# ── Server ───────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development          # development | production | test

# ── Database ─────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/college_events
# Production example:
# MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/college_events?retryWrites=true&w=majority
MONGO_POOL_SIZE=10            # connection pool size (default 10)

# ── JWT ──────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_use_a_64_char_random_hex_string
JWT_REFRESH_SECRET=CHANGE_ME_use_a_different_64_char_random_hex_string
JWT_ACCESS_EXPIRES=15m        # access token lifetime
JWT_REFRESH_EXPIRES=7d        # refresh token lifetime

# ── CORS / URLs ───────────────────────────────────────────────────
# Comma-separated list of allowed origins
CLIENT_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175
BASE_URL=http://localhost:5000

# ── File Uploads ─────────────────────────────────────────────────
UPLOAD_PATH=uploads           # relative to server root (no leading slash)
MAX_FILE_SIZE_MB=10           # per-file limit in MB
MAX_UPLOAD_FILES=5            # max files per request

# ── Rate Limiting ─────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes in ms
RATE_LIMIT_MAX_API=100        # max API requests per window
RATE_LIMIT_MAX_AUTH=10        # max auth attempts per window
RATE_LIMIT_MAX_UPLOAD=20      # max upload requests per hour

# ── Request Timeout ───────────────────────────────────────────────
REQUEST_TIMEOUT_MS=30000      # 30 seconds

# ── Cache ─────────────────────────────────────────────────────────
CACHE_TTL_SECONDS=300         # default NodeCache TTL
CACHE_CHECK_PERIOD=60         # expired key purge interval

# ── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=debug               # error | warn | info | http | debug
LOG_HEADERS=false             # set true to log sanitised request headers

# ── Admin Seed ────────────────────────────────────────────────────
ADMIN_EMAIL=admin@platform.com
ADMIN_PASSWORD=Admin@123456   # change before first deploy

# -- Brute-Force Protection ----------------------------------------
BRUTE_MAX_ATTEMPTS=5          # failed attempts before lockout (IP + account)
BRUTE_WINDOW_MS=900000        # tracking window in ms (15 min)
BRUTE_LOCKOUT_MS=1800000      # lockout duration in ms (30 min)
